# Rust
/target
**/*.rs.bk

# Cargo lockfile is committed (workspace contains a binary crate)

# Environment
.env
.env.local
.env.*.local

# Local, host-specific Docker Compose overrides (DNS, mounts, etc.)
docker-compose.override.yml

# macOS
.DS_Store
**/.DS_Store

# Editors / IDEs
*.swp
*.swo
*~
.idea/
.vscode/
*.iml

# OS
Thumbs.db

# Local agent tooling / config
.claude/

# Development-only artifacts — kept locally, not shipped
/READINESS.md
/docs/goals/
/scripts/smoke.md
/AGENTS.md

# Eval harness: personal corpora contain real thought content — never commit.
# The synthetic example corpus and the example arms file are the only
# committed eval assets. Reports are run artifacts.
/eval/corpora/*
!/eval/corpora/example.json
/eval/models.toml
/eval/reports/

# graphify — generated knowledge-graph output, regenerate with `graphify update .`
/graphify-out/
