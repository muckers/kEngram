  "query": "\n        SELECT id, migration, ran_at, rows_touched, notes\n        FROM migration_audit\n        WHERE ($1::timestamptz IS NULL OR ran_at >= $1)\n        ORDER BY ran_at DESC\n        LIMIT $2\n        ",
